{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "angular-cli": {
      "type": "local",
      "command": ["npx", "-y", "@angular/cli", "mcp"],
      "enabled": true
    },
    "browser-playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@j0hanz/filesystem-mcp", "--allow-cwd"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "lsp": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic-ai/cli-code", "--stdio", "--lsp"],
      "enabled": true
    },
    "eslint": {
      "type": "local",
      "command": ["npx", "-y", "eslint_mcp"],
      "enabled": true
    },
    "json-schema": {
      "type": "local",
      "command": ["npx", "-y", "@mcp-schema/json-schema-server"],
      "enabled": true
    },
    "playwright-chrome": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--browser=chromium"],
      "enabled": true
    }
  }
}
